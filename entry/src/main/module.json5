{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    // #110 A2 AppStartup：启动框架配置文件索引 + AbilityStage 源文件路径
    // 自动模式下，AbilityStage 创建后自动执行 startup_config.json 中配置的所有非 excludeFromAutoStart 任务
    "appStartup": "$profile:startup_config",
    "srcEntry": "./ets/entryability/EntryAbilityStage.ets",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        // #111 A3 声明 EntryAbility 可被 appRecovery 恢复（崩溃后自动重启此 Ability）
        "recoverable": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          },
          {
            // #109 A1 AppLinking：对齐 Android 原版 3 种 scheme 拦截配置
            // entity.system.browsable + ohos.want.action.viewData：声明可处理浏览类意图
            // 1. tblite://thread/{tid}              贴吧 Lite 内部自定义 scheme
            // 2. com.baidu.tieba://unidispatch      百度官方 scheme（query 携带 tid）
            // 3. https://tieba.baidu.com/p/{tid}    标准 web URL
            // 4. http://tieba.baidu.com/p/{tid}     同上（http 协议兜底）
            // domainVerify 默认 false：tieba.baidu.com 不属于本应用，无法通过 assetlinks.json 验证，
            // 用户点击链接时由系统选择器弹出（与 Android autoVerify=false 行为一致）
            "entities": [
              "entity.system.browsable"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "tblite",
                "host": "thread"
              },
              {
                "scheme": "com.baidu.tieba",
                "host": "unidispatch"
              },
              {
                "scheme": "https",
                "host": "tieba.baidu.com",
                "pathStartWith": "/p/"
              },
              {
                "scheme": "http",
                "host": "tieba.baidu.com",
                "pathStartWith": "/p/"
              }
            ]
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
  }
}